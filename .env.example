# Copie este arquivo para .env e preencha com seus valores
# cp .env.example .env

# ─── Perspective API (Google) ─────────────────────────────────────────────────
# Obtenha sua chave em: https://developers.perspectiveapi.com/
PERSPECTIVE_API_KEY=YOUR_KEY_HERE

# ─── Anthropic API (para Melhoria 3 — Dois Estágios + LLM) ───────────────────
# Obtenha sua chave em: https://console.anthropic.com/
ANTHROPIC_API_KEY=YOUR_KEY_HERE

# ─── Configurações do Modelo ──────────────────────────────────────────────────
# Diretório para salvar modelos treinados
MODEL_OUTPUT_DIR=./results/models

# Seed para reprodutibilidade
RANDOM_SEED=42
